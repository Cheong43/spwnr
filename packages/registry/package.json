{
  "name": "@spwnr/registry",
  "version": "0.3.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cheong43/spwnr-registry.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "provenance": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\" && tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@spwnr/core-types": "workspace:*",
    "@spwnr/manifest-schema": "workspace:*",
    "tar": "^7.4.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/tar": "^6.1.13",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
