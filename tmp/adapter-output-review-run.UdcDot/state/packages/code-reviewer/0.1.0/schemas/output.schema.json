{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeReviewerOutput",
  "type": "object",
  "required": ["summary", "issues"],
  "properties": {
    "summary": {
      "type": "string",
      "description": "High-level summary of the review"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "important", "minor", "suggestion"]
          },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "message": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "uri": { "type": "string" }
        }
      }
    }
  }
}
