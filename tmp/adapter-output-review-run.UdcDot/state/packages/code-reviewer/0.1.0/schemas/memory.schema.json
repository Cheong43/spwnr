{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeReviewerMemory",
  "type": "object",
  "properties": {
    "repoPreferences": {
      "type": "object",
      "description": "Repo-specific review preferences",
      "additionalProperties": { "type": "string" }
